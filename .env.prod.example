# The base URL where the application is hosted (Droplet IP + port)
HOST=http://YOUR_DROPLET_IP:3000

# Storage type for binary files (use 'local' for Droplet filesystem)
BLOB_STORAGE_TYPE=local

# Database type (keeping Supabase for database)
DB_TYPE=supabase

# Code Signing
# Base64 encoded private key for code signing
PRIVATE_KEY_BASE_64='your-base64-encoded-private-key'

# Admin password for the dashboard
ADMIN_PASSWORD=your-admin-password

# Supabase Database Configuration
SUPABASE_URL=your-supabase-project-url
SUPABASE_API_KEY=your-supabase-api-key
